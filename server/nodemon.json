{
  "exec": "npm run lint && node --import tsx src/server.ts",
  "_exec": "node --import tsx src/server.ts",
  "ext": "js,ts,json",
  "watch": ["./", "../packages/shared-schemas"],
  "delay": "2500",
  "ignore": [
    "node_modules/",
    "dist/",
    "uploads/",
    "prisma/migrations/",
    "../packages/*/dist/",
    "../packages/*/node_modules/"
  ]
}
