{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@school/common-ui": [
        "../common-ui/src/index.ts"
      ],
      "@school/shared-schemas": [
        "../shared-schemas/index.ts"
      ]
    },
    "jsx": "react-jsx",
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src",
    "src/**/*.d.ts"
  ]
}